# Database — use Neon (free PostgreSQL + pgvector, no inactivity pause)
# Get from: https://neon.tech → New Project → Connection Details
DATABASE_URL=postgresql+psycopg://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# Optional: LangSmith observability
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=mitra

# Local intent classifier (knowledge distillation — replaces Claude for routing)
# Train with: python ml/train_skill_gap_classifier.py
# Set LOCAL_CLASSIFIER_PATH to the saved adapter directory
USE_LOCAL_CLASSIFIER=false
LOCAL_CLASSIFIER_PATH=
